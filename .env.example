# =============================================================================
# Peeeky — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For production (Vercel), set ALL of these in Settings → Environment Variables.
# =============================================================================

# Database (Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Auth (NextAuth.js)
NEXTAUTH_URL="https://peeeky.com"                    # Production domain (http://localhost:3000 for dev)
NEXTAUTH_SECRET=""                                     # Generate: openssl rand -base64 32
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="https://peeeky.com"              # Must match NEXTAUTH_URL

# Email (Resend)
RESEND_API_KEY=""

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Stripe
STRIPE_SECRET_KEY=""                                   # sk_live_... for production, sk_test_... for dev
STRIPE_PUBLISHABLE_KEY=""                              # pk_live_... for production, pk_test_... for dev
STRIPE_WEBHOOK_SECRET=""                               # whsec_... from Stripe Dashboard → Webhooks

# AI (OpenAI — for AI Chat feature)
OPENAI_API_KEY=""

# Cron Jobs (Vercel Crons)
CRON_SECRET=""                                         # Generate: openssl rand -base64 32

# File Conversion (CloudConvert — for PPTX→PDF)
CLOUDCONVERT_API_KEY=""                                # Optional: only needed if PPTX upload is enabled

# Analytics (Optional)
NEXT_PUBLIC_GTM_ID=""                                  # Google Tag Manager ID (GTM-XXXXXXX)

# GitHub (for blog auto-publishing by blog-writer agent)
GITHUB_TOKEN=""                                        # Personal access token with contents:write

# Hunter.io (lead email enrichment — free tier: 50 credits/month, API included)
HUNTER_API_KEY=""                                      # API key from hunter.io/api-keys
